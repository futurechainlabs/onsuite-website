<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= t.nav.about %> - OnSuite | <%= data.site.title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/design-system.css">
  <link rel="stylesheet" href="/css/pages.css">
  <link rel="stylesheet" href="/css/inner.css">
  <link rel="icon" type="image/png" href="/assets/images/favicon.png">
</head>
<body>
<%- include('partials/header') %>

<main id="main-content">
<section class="inner-hero">
  <div class="container">
    <h1 class="inner-hero__title"><%= t.about.heroTitle %></h1>
    <p class="inner-hero__desc"><%= t.about.heroDesc %></p>
  </div>
</section>

<section class="about-story">
  <div class="container">
    <div class="about-story__grid">
      <% t.about.timeline.forEach(function(item) { %>
        <div class="about-story__item">
          <span class="about-story__year"><%= item.year %></span>
          <h3 class="about-story__heading"><%= item.title %></h3>
          <p class="about-story__text"><%= item.text %></p>
        </div>
      <% }); %>
    </div>
  </div>
</section>

<section class="inner-stats" style="background:#FAFBFC">
  <div class="container">
    <div class="inner-stats__grid">
      <% t.about.stats.forEach(function(s) { %>
        <div class="inner-stats__item">
          <span class="inner-stats__value" style="color:<%= s.color %>"><%= s.value %></span>
          <span class="inner-stats__label"><%= s.label %></span>
        </div>
      <% }); %>
    </div>
  </div>
</section>

<section class="about-values">
  <div class="container">
    <h2 class="inner-section-title"><%= t.about.values %></h2>
    <div class="about-values__grid">
      <div class="about-values__card">
        <div class="about-values__icon" style="color:#0089CF">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
        </div>
        <h3 class="about-values__name"><%= t.about.fieldExp %></h3>
        <p class="about-values__desc"><%= t.about.fieldExpDesc %></p>
      </div>
      <div class="about-values__card">
        <div class="about-values__icon" style="color:#04bf8a">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        </div>
        <h3 class="about-values__name"><%= t.about.resultOriented %></h3>
        <p class="about-values__desc"><%= t.about.resultOrientedDesc %></p>
      </div>
      <div class="about-values__card">
        <div class="about-values__icon" style="color:#ff3b78">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2M9 11a4 4 0 100-8 4 4 0 000 8zM23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
        </div>
        <h3 class="about-values__name"><%= t.about.longTermPartner %></h3>
        <p class="about-values__desc"><%= t.about.longTermPartnerDesc %></p>
      </div>
    </div>
  </div>
</section>

<section class="about-contact">
  <div class="container">
    <div class="about-contact__grid">
      <div class="about-contact__info">
        <h2 class="inner-section-title" style="text-align:left"><%= t.about.contact %></h2>
        <div class="about-contact__item">
          <strong><%= t.about.address %></strong>
          <p><%= t.about.addressVal %></p>
        </div>
        <div class="about-contact__item">
          <strong><%= t.about.phoneLabel %></strong>
          <p><a href="tel:+902322450076"><%= t.common.phone %></a></p>
        </div>
        <div class="about-contact__item">
          <strong><%= t.about.emailLabel %></strong>
          <p><a href="mailto:info@siskon.com.tr">info@siskon.com.tr</a></p>
        </div>
      </div>
      <div class="about-contact__cta">
        <h3><%= t.about.talkProjects %></h3>
        <p><%= t.about.talkDesc %></p>
        <a href="<%= prefix %>/demo" class="btn btn--primary"><%= t.common.demoRequestBtn %> <span>&rarr;</span></a>
      </div>
    </div>
  </div>
</section>
</main>

<%- include('partials/footer') %>
<%- include('partials/chatbot') %>
<script src="/js/main.js"></script>
</body>
</html>
