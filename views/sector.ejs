<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= sector.name %> - OnSuite | <%= data.site.title %></title>
  <meta name="description" content="<%= sector.description %>">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/design-system.css">
  <link rel="stylesheet" href="/css/pages.css">
  <link rel="stylesheet" href="/css/inner.css">
  <link rel="icon" type="image/png" href="/assets/images/favicon.png">
</head>
<body>
<%- include('partials/header') %>

<main id="main-content">
<section class="inner-hero" style="--accent: <%= sector.color %>">
  <div class="container">
    <nav class="inner-hero__breadcrumb" aria-label="Breadcrumb">
      <a href="<%= prefix %>/"><%= t.common.home %></a><span>/</span>
      <a href="<%= prefix %>/<%= lang === 'en' ? 'industries' : 'sektorler' %>"><%= t.common.sectors %></a><span>/</span>
      <span><%= sector.name %></span>
    </nav>
    <h1 class="inner-hero__title"><%= sector.title %></h1>
    <p class="inner-hero__desc"><%= sector.description %></p>
    <div class="inner-hero__actions">
      <a href="<%= prefix %>/demo?sector=<%= sector.slug %>" class="btn btn--primary"><%= t.common.demoRequestBtn %> <span>&rarr;</span></a>
    </div>
  </div>
</section>

<section class="inner-stats">
  <div class="container">
    <div class="inner-stats__grid">
      <% sector.stats.forEach(function(s) { %>
        <div class="inner-stats__item">
          <span class="inner-stats__value" style="color: <%= sector.color %>"><%= s.value %></span>
          <span class="inner-stats__label"><%= s.label %></span>
        </div>
      <% }); %>
    </div>
  </div>
</section>

<section class="inner-split">
  <div class="container">
    <div class="inner-split__grid">
      <div class="inner-split__col inner-split__col--problem">
        <h2 class="inner-split__heading"><%= t.sector.challenges %></h2>
        <ul class="inner-split__list">
          <% sector.challenges.forEach(function(c) { %>
            <li><svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M13.5 4.5L4.5 13.5M4.5 4.5l9 9" stroke="#ff3b78" stroke-width="2" stroke-linecap="round"/></svg><%= c %></li>
          <% }); %>
        </ul>
      </div>
      <div class="inner-split__col inner-split__col--solution">
        <h2 class="inner-split__heading"><%= t.sector.solutions %></h2>
        <ul class="inner-split__list">
          <% sector.solutions.forEach(function(s) { %>
            <li><svg width="18" height="18" viewBox="0 0 18 18" fill="none"><path d="M4 9l3.5 3.5L14 5" stroke="#04bf8a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg><%= s %></li>
          <% }); %>
        </ul>
      </div>
    </div>
  </div>
</section>

<section class="inner-modules">
  <div class="container">
    <h2 class="inner-section-title"><%= sector.name %> <%= t.sector.recommendedModules %></h2>
    <div class="inner-modules__grid">
      <% var modPath = lang === 'en' ? 'modules' : 'moduller'; %>
      <% sector.modules.forEach(function(slug) { if (modulesData[slug]) { var m = modulesData[slug]; %>
        <a href="<%= prefix %>/<%= modPath %>/<%= slug %>" class="inner-modules__card">
          <div class="inner-modules__color" style="background: <%= m.color %>"></div>
          <h3 class="inner-modules__name"><%= m.name %></h3>
          <p class="inner-modules__desc"><%= m.tagline %></p>
          <span class="inner-modules__link"><%= t.common.learnMore %> <span>&rarr;</span></span>
        </a>
      <% } }); %>
    </div>
  </div>
</section>

<% if (sector.references && sector.references.length > 0) { %>
<section class="inner-refs">
  <div class="container">
    <h2 class="inner-section-title"><%= t.sector.referencesInSector %></h2>
    <div class="inner-refs__grid">
      <% sector.references.forEach(function(ref) { %>
        <div class="inner-refs__item"><%= ref %></div>
      <% }); %>
    </div>
  </div>
</section>
<% } %>

<section class="inner-cta">
  <div class="container">
    <div class="inner-cta__inner">
      <h2 class="inner-cta__title"><%= sector.name %> <%= t.sector.startDigital %></h2>
      <p class="inner-cta__desc"><%= t.sector.ctaDesc %></p>
      <div class="inner-cta__actions">
        <a href="<%= prefix %>/demo?sector=<%= sector.slug %>" class="btn btn--primary btn--lg"><%= t.common.demoRequestBtn %> <span>&rarr;</span></a>
        <a href="tel:+902322450076" class="btn btn--ghost"><%= t.common.phone %></a>
      </div>
    </div>
  </div>
</section>
</main>

<%- include('partials/footer') %>
<%- include('partials/chatbot') %>
<script src="/js/main.js"></script>
</body>
</html>
