          <div class="footer__social">
            <a href="#" aria-label="LinkedIn" class="footer__social-link"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg></a>
            <a href="#" aria-label="YouTube" class="footer__social-link"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg></a>
          </div>
        </div>
      </div>
    </div>
  </footer>

  <!-- ============================================================
       CHATBOT WIDGET
       ============================================================ -->
  <div class="chatbot" id="chatbot">
    <button class="chatbot__trigger" id="chatbotTrigger" aria-label="OnSuite Asistan">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <div class="chatbot__teaser" id="chatbotTeaser" hidden>
      <p>Size nasil yardimci olabilirim?</p>
      <button class="chatbot__teaser-close" aria-label="Kapat">&times;</button>
    </div>
    <div class="chatbot__panel" id="chatbotPanel" hidden>
      <div class="chatbot__header">
        <div class="chatbot__header-info">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" stroke="#fff" stroke-width="1.5"/></svg>
          <span>OnSuite Asistan</span>
        </div>
        <button class="chatbot__minimize" id="chatbotMinimize" aria-label="Kucult"><svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 8h8" stroke="#fff" stroke-width="1.5" stroke-linecap="round"/></svg></button>
      </div>
      <div class="chatbot__messages" id="chatbotMessages">
        <div class="chatbot__msg chatbot__msg--bot"><p>Merhaba! OnSuite hakkinda ne ogrenmek istersiniz?</p></div>
        <div class="chatbot__quick-replies">
          <button class="chatbot__chip" data-reply="modules">Moduller</button>
          <button class="chatbot__chip" data-reply="demo">Demo</button>
          <button class="chatbot__chip" data-reply="tech">Teknik Destek</button>
        </div>
      </div>
      <div class="chatbot__input-bar">
        <input type="text" class="chatbot__input" placeholder="Mesajinizi yazin..." aria-label="Mesaj">
        <button class="chatbot__send" aria-label="Gonder"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z" stroke="var(--blue-500)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></button>
      </div>
    </div>
  </div>

  <script src="js/main.js"></script>
</body>
</html>