      </div>
      <div class="footer__bottom">
        <p class="footer__copy">&copy; <%= data.site.copyright %></p>
        <div class="footer__bottom-right">
          <div class="lang-switch">
            <button class="lang-switch__btn lang-switch__btn--active" style="color:#fff">TR</button>
            <span class="lang-switch__sep" style="color:rgba(255,255,255,.3)">|</span>
