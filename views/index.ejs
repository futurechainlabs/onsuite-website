<!DOCTYPE html>
<html lang="<%= lang %>" data-theme="light">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="<%= data.site.description %>">
  <title><%= data.site.title %></title>

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">

  <!-- Styles -->
  <link rel="stylesheet" href="/css/design-system.css">
  <link rel="stylesheet" href="/css/pages.css">
  <link rel="icon" type="image/png" href="/assets/images/favicon.png">
</head>
<body>

  <!-- Cursor-following glow (desktop only) -->
  <div class="cursor-glow" id="cursorGlow" aria-hidden="true"></div>

  <%- include('partials/header') %>

  <main id="main-content">

    <!-- ============================================================
         SECTION 1: HERO (v6)
         ============================================================ -->
    <section class="hero" id="hero">
      <div class="hero__particle hero__particle--1" aria-hidden="true"></div>
      <div class="hero__particle hero__particle--2" aria-hidden="true"></div>
      <div class="hero__particle hero__particle--3" aria-hidden="true"></div>
      <div class="hero__particle hero__particle--4" aria-hidden="true"></div>
      <div class="hero__particle hero__particle--5" aria-hidden="true"></div>

      <div class="container hero__inner">
        <div class="hero__content">
          <div class="badge reveal">
            <span class="badge__dot"></span>
            <%= data.hero.badge %>
          </div>
          <h1 class="hero__title reveal reveal-d1">
            <%= data.hero.titleLine1 %><br><span class="hero__highlight"><%= data.hero.titleHighlight %></span><br><%= data.hero.titleLine3 %>
          </h1>

          <ul class="hero__feats reveal reveal-d2">
            <% data.hero.feats.forEach(function(feat) { %>
            <li class="hero__feat">
              <span class="hero__feat-dot" aria-hidden="true">&#10003;</span>
              <%= feat %>
            </li>
            <% }) %>
          </ul>

          <div class="hero__actions reveal reveal-d3">
            <a href="<%= prefix %>/demo" class="btn btn--primary">
              <%= data.hero.ctaPrimary %>
              <svg class="btn__arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3.33 8h9.34M8.67 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="#products" class="btn btn--secondary"><%= data.hero.ctaSecondary %></a>
            <a href="<%= prefix %>/referanslar" class="btn btn--ghost"><%= t.home.references %></a>
          </div>

          <div class="hero__badges reveal reveal-d3">
            <% data.hero.badges.forEach(function(b) { %>
            <span class="hero__badge hero__badge--<%= b.color %>"><%= b.label %></span>
            <% }) %>
          </div>
        </div>

        <div class="hero__visual reveal reveal-d2">
          <div class="canvas-shell">
            <div class="canvas-shell__bar">
              <span class="canvas-shell__dots" aria-hidden="true">
                <i></i><i></i><i></i>
              </span>
              <span class="canvas-shell__title">OnSuite — Live Dashboard</span>
            </div>
            <canvas id="cHero" width="580" height="330"></canvas>
          </div>

          <!-- Floating stat cards -->
          <div class="hero__float hero__float--oee reveal reveal-d3">
            <span class="hero__float-label">OEE</span>
            <span class="hero__float-value">87.4%</span>
          </div>
          <div class="hero__float hero__float--uptime reveal reveal-d3">
            <span class="hero__float-label">Uptime</span>
            <span class="hero__float-value">99.2%</span>
          </div>

          <!-- Mobile fallback -->
          <div class="hero-mobile-fallback">
            <div class="hero-mobile-fallback__box">
              <span class="hero-mobile-fallback__value">87%</span>
              <span class="hero-mobile-fallback__label">OEE</span>
            </div>
            <div class="hero-mobile-fallback__box">
              <span class="hero-mobile-fallback__value">&lt;2s</span>
              <span class="hero-mobile-fallback__label">Gecikme</span>
            </div>
            <div class="hero-mobile-fallback__box">
              <span class="hero-mobile-fallback__value">99%</span>
              <span class="hero-mobile-fallback__label">Uptime</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         SECTION 2: STATS STRIP
         ============================================================ -->
    <div class="stats-strip">
      <div class="container stats-strip__row">
        <% data.statsStrip.forEach(function(s) { %>
        <div class="stats-strip__item">
          <div class="stats-strip__value"><%= s.value %></div>
          <div class="stats-strip__label"><%= s.label %></div>
        </div>
        <% }) %>
      </div>
    </div>

    <!-- ============================================================
         SECTION 3: SOCIAL PROOF BAR (KEEP)
         ============================================================ -->
    <section class="proof-bar" aria-label="<%= t.home.references %>">
      <div class="container">
        <div class="proof-bar__logos reveal">
          <img src="/assets/images/logos/references/bosch.png" alt="Bosch" class="proof-bar__logo" loading="lazy">
          <img src="/assets/images/logos/references/bsh.png" alt="BSH" class="proof-bar__logo" loading="lazy">
          <img src="/assets/images/logos/references/haier-europe.png" alt="Haier Europe" class="proof-bar__logo" loading="lazy">
          <img src="/assets/images/logos/references/unilever.png" alt="Unilever" class="proof-bar__logo" loading="lazy">
          <img src="/assets/images/logos/references/pmi.png" alt="Philip Morris" class="proof-bar__logo" loading="lazy">
          <img src="/assets/images/logos/references/borgwarner.png" alt="BorgWarner" class="proof-bar__logo" loading="lazy">
          <img src="/assets/images/logos/references/diageo.png" alt="Diageo" class="proof-bar__logo" loading="lazy">
          <img src="/assets/images/logos/references/jti.png" alt="JTI" class="proof-bar__logo" loading="lazy">
          <img src="/assets/images/logos/references/maxion.png" alt="Maxion" class="proof-bar__logo" loading="lazy">
        </div>
        <div class="proof-bar__metrics reveal reveal-d1">
          <% data.proofBar.metrics.forEach(function(m, i) { %>
          <div class="proof-bar__metric">
            <span class="proof-bar__number" data-count="<%= m.count %>">0</span><span class="proof-bar__plus">+</span>
            <span class="proof-bar__label"><%= m.label %></span>
          </div>
          <% if (i < data.proofBar.metrics.length - 1) { %>
          <span class="proof-bar__sep" aria-hidden="true">&middot;</span>
          <% } %>
          <% }) %>
        </div>
      </div>
    </section>

    <!-- ============================================================
         SECTION 4: REFERENCE METRICS
         ============================================================ -->
    <section class="section section--dark ref-metrics" id="ref-metrics">
      <div class="container">
        <div class="ref-metrics__header">
          <p class="section__overline reveal"><%= t.home.references %></p>
          <h2 class="section__title reveal reveal-d1" style="color:#fff">
            Musterilerimizin <span class="text-gradient">olculebilir sonuclari</span>
          </h2>
        </div>

        <div class="ref-metrics__grid">
          <% data.refMetrics.forEach(function(rm) { %>
          <div class="ref-metrics__card ref-metrics__card--<%= rm.color %> reveal">
            <div class="ref-metrics__value"><%= rm.value %></div>
            <div class="ref-metrics__label"><%= rm.label %></div>
            <p class="ref-metrics__desc"><%= rm.desc %></p>
            <div class="ref-metrics__tags">
              <% rm.tags.forEach(function(tag) { %>
              <span class="ref-metrics__tag"><%= tag %></span>
              <% }) %>
            </div>
          </div>
          <% }) %>
        </div>

        <div class="sector-cases reveal">
          <% data.sectorCases.forEach(function(sc) { %>
          <div class="sector-case">
            <div class="sector-case__icon sector-case__icon--<%= sc.icon %>" aria-hidden="true"></div>
            <h4 class="sector-case__title"><%= sc.title %></h4>
            <p class="sector-case__desc"><%= sc.desc %></p>
            <div class="sector-case__modules">
              <% sc.modules.forEach(function(mod) { %>
              <span class="sector-case__module"><%= mod %></span>
              <% }) %>
            </div>
          </div>
          <% }) %>
        </div>

        <div class="text-center reveal" style="margin-top:3rem">
          <a href="<%= prefix %>/referanslar" class="btn btn--primary">
            <%= t.home.references %>
            <svg class="btn__arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3.33 8h9.34M8.67 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ============================================================
         SECTION 5: FEATURE — CONNECT (light bg)
         ============================================================ -->
    <section class="section feat-section" id="feat-connect">
      <div class="container">
        <div class="feat-section__grid">
          <div class="feat-section__canvas reveal">
            <div class="canvas-shell">
              <div class="canvas-shell__bar">
                <span class="canvas-shell__dots" aria-hidden="true"><i></i><i></i><i></i></span>
                <span class="canvas-shell__title">Connect — Data Flow</span>
              </div>
              <canvas id="cConnect" width="520" height="300"></canvas>
            </div>
          </div>
          <div class="feat-section__text reveal reveal-d1">
            <span class="feat-section__tag"><%= data.featureSections.connect.tag %></span>
            <h2 class="feat-section__title">
              <%= data.featureSections.connect.title %> <span class="text-gradient"><%= data.featureSections.connect.titleHighlight %></span>
            </h2>
            <p class="feat-section__desc"><%= data.featureSections.connect.desc %></p>
            <div class="feat-section__chips">
              <% data.featureSections.connect.chips.forEach(function(chip) { %>
              <span class="feat-section__chip"><%= chip %></span>
              <% }) %>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         SECTION 6: FEATURE — OPTIMA (dark bg, flipped)
         ============================================================ -->
    <section class="section feat-section feat-section--dark" id="feat-optima">
      <div class="container">
        <div class="feat-section__grid feat-section__grid--flip">
          <div class="feat-section__text reveal">
            <span class="feat-section__tag"><%= data.featureSections.optima.tag %></span>
            <h2 class="feat-section__title" style="color:#fff">
              <%= data.featureSections.optima.title %> <span class="text-gradient"><%= data.featureSections.optima.titleHighlight %></span>
            </h2>
            <p class="feat-section__desc"><%= data.featureSections.optima.desc %></p>
            <div class="feat-section__chips">
              <% data.featureSections.optima.chips.forEach(function(chip) { %>
              <span class="feat-section__chip"><%= chip %></span>
              <% }) %>
            </div>
          </div>
          <div class="feat-section__canvas reveal reveal-d1">
            <div class="canvas-shell">
              <div class="canvas-shell__bar">
                <span class="canvas-shell__dots" aria-hidden="true"><i></i><i></i><i></i></span>
                <span class="canvas-shell__title">Optima — OEE Waterfall</span>
              </div>
              <canvas id="cOptima" width="520" height="300"></canvas>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         SECTION 7: FEATURE — TRACE (alt bg)
         ============================================================ -->
    <section class="section feat-section feat-section--alt" id="feat-trace">
      <div class="container">
        <div class="feat-section__grid">
          <div class="feat-section__canvas reveal">
            <div class="canvas-shell">
              <div class="canvas-shell__bar">
                <span class="canvas-shell__dots" aria-hidden="true"><i></i><i></i><i></i></span>
                <span class="canvas-shell__title">Trace — Lot Flow</span>
              </div>
              <canvas id="cTrace" width="520" height="300"></canvas>
            </div>
          </div>
          <div class="feat-section__text reveal reveal-d1">
            <span class="feat-section__tag"><%= data.featureSections.trace.tag %></span>
            <h2 class="feat-section__title">
              <%= data.featureSections.trace.title %> <span class="text-gradient"><%= data.featureSections.trace.titleHighlight %></span>
            </h2>
            <p class="feat-section__desc"><%= data.featureSections.trace.desc %></p>
            <ul class="feat-section__bullets">
              <% data.featureSections.trace.bullets.forEach(function(b) { %>
              <li class="feat-section__bullet">
                <strong><%= b.title %></strong>
                <span><%= b.desc %></span>
              </li>
              <% }) %>
            </ul>
            <div class="feat-section__chips">
              <% data.featureSections.trace.chips.forEach(function(chip) { %>
              <span class="feat-section__chip"><%= chip %></span>
              <% }) %>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         SECTION 8: PRODUCTS GRID
         ============================================================ -->
    <section class="section products-section" id="products">
      <div class="container">
        <div class="section__header">
          <p class="section__overline reveal"><%= data.productsGrid.overline %></p>
          <h2 class="section__title reveal reveal-d1"><%= data.productsGrid.title %> <span class="text-gradient"><%= data.productsGrid.titleHighlight %></span></h2>
          <p class="section__sub reveal reveal-d2"><%= data.productsGrid.subtitle %></p>
        </div>

        <!-- Backbone products (4 featured) -->
        <div class="products-grid products-grid--backbone">
          <% data.productsGrid.backbone.forEach(function(p) { %>
          <div class="product-card product-card--featured reveal" style="--card-accent:<%= p.color %>">
            <div class="product-card__icon product-card__icon--<%= p.icon %>" aria-hidden="true"></div>
            <h3 class="product-card__name"><%= p.name %></h3>
            <p class="product-card__desc"><%= p.desc %></p>
            <div class="product-card__tags">
              <% p.tags.forEach(function(tag) { %>
              <span class="product-card__tag"><%= tag %></span>
              <% }) %>
            </div>
          </div>
          <% }) %>
        </div>

        <hr class="products-section__divider reveal" aria-hidden="true">

        <!-- Complementary products (6 regular) -->
        <div class="products-grid products-grid--complementary">
          <% data.productsGrid.complementary.forEach(function(p) { %>
          <div class="product-card reveal" style="--card-accent:<%= p.color %>">
            <div class="product-card__icon product-card__icon--<%= p.icon %>" aria-hidden="true"></div>
            <h3 class="product-card__name"><%= p.name %></h3>
            <p class="product-card__desc"><%= p.desc %></p>
            <div class="product-card__tags">
              <% p.tags.forEach(function(tag) { %>
              <span class="product-card__tag"><%= tag %></span>
              <% }) %>
            </div>
          </div>
          <% }) %>
        </div>
      </div>
    </section>

    <!-- ============================================================
         SECTION 9: VALUE TABS
         ============================================================ -->
    <section class="section section--dark value-section" id="value">
      <div class="container">
        <div class="section__header">
          <p class="section__overline reveal"><%= data.valueTabs.overline %></p>
          <h2 class="section__title reveal reveal-d1" style="color:#fff"><%= data.valueTabs.title %> <span class="text-gradient"><%= data.valueTabs.titleHighlight %></span></h2>
          <p class="section__sub reveal reveal-d2"><%= data.valueTabs.subtitle %></p>
        </div>

        <div class="value-section__tabs reveal" role="tablist">
          <% data.valueTabs.tabs.forEach(function(tab, i) { %>
          <button class="value-section__tab<%= i === 0 ? ' value-section__tab--active' : '' %>"
                  role="tab"
                  aria-selected="<%= i === 0 ? 'true' : 'false' %>"
                  data-vtab="<%= i %>">
            <span class="value-section__tab-icon value-section__tab-icon--<%= tab.icon %>" aria-hidden="true"></span>
            <%= tab.label %>
          </button>
          <% }) %>
        </div>

        <div class="value-section__grid">
          <div class="value-section__panels">
            <% data.valueTabs.tabs.forEach(function(tab, i) { %>
            <div class="value-section__body<%= i === 0 ? ' value-section__body--active' : '' %>"
                 role="tabpanel"
                 data-vpanel="<%= i %>"
                 <% if (i !== 0) { %>hidden<% } %>>
              <div class="value-section__points">
                <% tab.points.forEach(function(pt) { %>
                <div class="value-point">
                  <div class="value-point__icon value-point__icon--<%= pt.icon %>" aria-hidden="true"></div>
                  <div>
                    <strong class="value-point__title"><%= pt.title %></strong>
                    <p class="value-point__desc"><%= pt.desc %></p>
                  </div>
                </div>
                <% }) %>
              </div>
            </div>
            <% }) %>
          </div>
          <div class="value-section__canvas">
            <canvas id="cValue" width="480" height="280"></canvas>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         SECTION 10: INTEGRATION ECOSYSTEM (KEEP)
         ============================================================ -->
    <section class="section" id="integrations">
      <div class="container">
        <div class="section__header">
          <p class="section__overline reveal"><%= t.home.integrationOverline %></p>
          <h2 class="section__title reveal reveal-d1"><%= t.home.integrationTitle %> <span class="text-gradient"><%= t.home.integrationHighlight %></span></h2>
          <p class="section__sub reveal reveal-d2"><%= t.home.integrationDesc %></p>
        </div>

        <div class="partner-grid reveal">
          <div class="partner-card"><img src="/assets/images/logos/partners/microsoft.png" alt="Microsoft" class="partner-card__logo" loading="lazy"></div>
          <div class="partner-card"><img src="/assets/images/logos/partners/beckhoff.png" alt="Beckhoff" class="partner-card__logo" loading="lazy"></div>
          <div class="partner-card"><img src="/assets/images/logos/partners/ge-vernova.png" alt="GE Vernova" class="partner-card__logo" loading="lazy"></div>
          <div class="partner-card"><img src="/assets/images/logos/partners/inginition.png" alt="Ignition" class="partner-card__logo" loading="lazy"></div>
          <div class="partner-card"><img src="/assets/images/logos/partners/sick.png" alt="SICK" class="partner-card__logo" loading="lazy"></div>
          <div class="partner-card"><img src="/assets/images/logos/partners/universal-robots.png" alt="Universal Robots" class="partner-card__logo" loading="lazy"></div>
          <div class="partner-card"><img src="/assets/images/logos/partners/sewio.png" alt="Sewio" class="partner-card__logo" loading="lazy"></div>
          <div class="partner-card"><img src="/assets/images/logos/partners/markem-maje.png" alt="Markem-Imaje" class="partner-card__logo" loading="lazy"></div>
          <div class="partner-card"><img src="/assets/images/logos/partners/interroll.png" alt="Interroll" class="partner-card__logo" loading="lazy"></div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         SECTION 11: TESTIMONIAL (KEEP)
         ============================================================ -->
    <section class="section section--alt" id="testimonial">
      <div class="container">
        <div class="section__header">
          <p class="section__overline reveal"><%= t.home.testimonialOverline %></p>
          <h2 class="section__title reveal reveal-d1"><%= t.home.testimonialTitle %> <span class="text-gradient"><%= t.home.testimonialHighlight %></span></h2>
        </div>

        <div class="testimonial-card reveal">
          <div class="testimonial-card__quote" aria-hidden="true">&ldquo;</div>
          <blockquote class="testimonial-card__text">
            <%= data.testimonial.quote %>
          </blockquote>
          <div class="testimonial-card__author">
            <div class="testimonial-card__avatar"><%= data.testimonial.initials %></div>
            <div>
              <strong class="testimonial-card__name"><%= data.testimonial.name %></strong>
              <span class="testimonial-card__role"><%= data.testimonial.role %></span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         SECTION 12: ROI CALCULATOR (KEEP)
         ============================================================ -->
    <section class="section" id="roi">
      <div class="container">
        <div class="section__header">
          <p class="section__overline reveal"><%= t.home.roiOverline %></p>
          <h2 class="section__title reveal reveal-d1"><%= t.home.roiTitle %> <span class="text-gradient"><%= t.home.roiHighlight %></span> <%= t.home.roiTitleEnd %></h2>
          <p class="section__sub reveal reveal-d2"><%= t.home.roiDesc %></p>
        </div>

        <div class="roi-calc reveal">
          <div class="roi-calc__inputs">
            <div class="roi-calc__field">
              <label class="roi-calc__label"><%= t.home.roiLines %></label>
              <input type="range" class="roi-calc__slider" id="roiLines" min="1" max="50" value="8">
              <div class="roi-calc__value"><span id="roiLinesVal">8</span></div>
            </div>
            <div class="roi-calc__field">
              <label class="roi-calc__label"><%= t.home.roiOee %></label>
              <input type="range" class="roi-calc__slider" id="roiOee" min="30" max="90" value="65">
              <div class="roi-calc__value"><span id="roiOeeVal">65%</span></div>
            </div>
            <div class="roi-calc__field">
              <label class="roi-calc__label"><%= t.home.roiDowntime %></label>
              <input type="range" class="roi-calc__slider" id="roiDowntime" min="10" max="500" value="80" step="10">
              <div class="roi-calc__value"><span id="roiDowntimeVal">80</span></div>
            </div>
            <div class="roi-calc__field">
              <label class="roi-calc__label"><%= t.home.roiSector %></label>
              <select class="roi-calc__select" id="roiSector">
                <option value="general"><%= t.home.roiSectorGeneral %></option>
                <option value="automotive"><%= t.home.roiSectorAuto %></option>
                <option value="food"><%= t.home.roiSectorFood %></option>
                <option value="pharma"><%= t.home.roiSectorPharma %></option>
                <option value="tobacco"><%= t.home.roiSectorTobacco %></option>
              </select>
            </div>
            <div class="roi-calc__field">
              <label class="roi-calc__label"><%= t.home.roiVolume %></label>
              <input type="range" class="roi-calc__slider" id="roiVolume" min="10000" max="10000000" value="500000" step="10000">
              <div class="roi-calc__value"><span id="roiVolumeVal">500K</span></div>
            </div>
          </div>

          <div class="roi-calc__results">
            <span class="roi-calc__results-label"><%= t.home.roiResultLabel %></span>
            <div class="roi-calc__big-number">
              <span class="roi-calc__currency">&#8378;</span>
              <span class="roi-calc__amount" id="roiAmount">1.2M</span>
            </div>
            <div class="roi-calc__breakdown">
              <div class="roi-calc__row"><span><%= t.home.roiOeeGain %></span><span class="roi-calc__row-value" id="roiOeeGain" style="color:var(--success-light)">+12%</span></div>
              <div class="roi-calc__row"><span><%= t.home.roiDowntimeGain %></span><span class="roi-calc__row-value" id="roiDowntimeGain" style="color:var(--success-light)">-30%</span></div>
              <div class="roi-calc__row"><span><%= t.home.roiScrapGain %></span><span class="roi-calc__row-value" id="roiScrapGain" style="color:var(--success-light)">-18%</span></div>
              <div class="roi-calc__row"><span><%= t.home.roiPayback %></span><span class="roi-calc__row-value" id="roiPayback" style="color:var(--cyan-200)">9 <%= t.home.roiPaybackUnit %></span></div>
            </div>
            <div class="roi-calc__actions">
              <a href="<%= prefix %>/demo" class="btn btn--primary" style="width:100%">
                <%= t.home.roiCta %>
                <svg class="btn__arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3.33 8h9.34M8.67 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         SECTION 13: DEMO CTA BLOCK (KEEP)
         ============================================================ -->
    <section class="section section--dark cta-block" id="demo">
      <div class="container text-center" style="position:relative;z-index:1">
        <h2 class="section__title reveal" style="color:#fff"><%= data.cta.title %> <span style="color:var(--cyan-200)"><%= data.cta.titleHighlight %></span> <%= data.cta.titleEnd %></h2>
        <p class="section__sub reveal reveal-d1" style="color:rgba(255,255,255,.55)"><%= data.cta.subtitle %></p>
        <div class="cta-block__actions reveal reveal-d2">
          <a href="<%= prefix %>/demo" class="btn btn--primary">
            <%= t.home.ctaDemoBtn %>
            <svg class="btn__arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3.33 8h9.34M8.67 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
          <a href="<%= data.site.phoneHref %>" class="btn btn--ghost"><%= t.home.ctaCallBtn %></a>
        </div>
        <p class="cta-block__phone reveal reveal-d3"><%= t.home.ctaPhoneText %> <a href="<%= data.site.phoneHref %>"><%= data.site.phone %></a></p>
      </div>
      <div class="cta-block__pattern" aria-hidden="true"></div>
    </section>

  </main>

  <%- include('partials/footer') %>
  <%- include('partials/chatbot') %>

  <script src="/js/main.js"></script>
  <script src="/js/canvas-animations.js" defer></script>
  <script>
  document.addEventListener('DOMContentLoaded', function() {
    // Value Tabs click handler
    var vtabs = document.querySelectorAll('[data-vtab]');
    var vpanels = document.querySelectorAll('[data-vpanel]');
    vtabs.forEach(function(btn) {
      btn.addEventListener('click', function() {
        var idx = +btn.dataset.vtab;
        vtabs.forEach(function(b) { b.classList.remove('value-section__tab--active'); b.setAttribute('aria-selected','false'); });
        btn.classList.add('value-section__tab--active'); btn.setAttribute('aria-selected','true');
        vpanels.forEach(function(p) { p.classList.remove('value-section__body--active'); p.hidden = true; });
        var target = document.querySelector('[data-vpanel="'+idx+'"]');
        if (target) { target.classList.add('value-section__body--active'); target.hidden = false; }
        if (window.setValueTab) window.setValueTab(idx);
      });
    });
  });
  </script>
</body>
</html>
