<!-- ============================================================
     FOOTER
     ============================================================ -->
<footer class="footer">
  <div class="container">
    <div class="footer__grid">
      <div class="footer__brand">
        <img src="/assets/images/logo.png" alt="OnSuite" class="footer__logo" style="filter:brightness(0) invert(1)" width="140" height="32">
        <p class="footer__desc"><%= lang === 'en' ? 'Manage your factory from a single smart platform. Siskon Automation\'s production management solution.' : 'Fabrikanizi tek bir akilli platformdan yonetin. Siskon Otomasyon\'un uretim yonetim cozumu.' %></p>
      </div>
      <% var modPath = lang === 'en' ? 'modules' : 'moduller'; %>
      <div class="footer__col">
        <h6 class="footer__heading" data-accordion><%= t.footer.platform %></h6>
        <ul class="footer__links">
          <li><a href="<%= prefix %>/<%= lang === 'en' ? 'industries' : 'sektorler' %>"><%= t.nav.sectors %></a></li>
          <li><a href="<%= prefix %>/<%= modPath %>/onoee"><%= t.nav.oeePerf %></a></li>
          <li><a href="<%= prefix %>/<%= modPath %>/onmonitora"><%= lang === 'en' ? 'Machine Monitoring' : 'Makine Izleme' %></a></li>
          <li><a href="<%= prefix %>/<%= modPath %>/onintegra"><%= t.nav.integration %></a></li>
        </ul>
      </div>
      <div class="footer__col">
        <h6 class="footer__heading" data-accordion><%= t.footer.modules %></h6>
        <ul class="footer__links">
          <li><a href="<%= prefix %>/<%= modPath %>/ontrace">OnTrace</a></li>
          <li><a href="<%= prefix %>/<%= modPath %>/onoptima">OnOptima</a></li>
          <li><a href="<%= prefix %>/<%= modPath %>/onoee">OnOEE</a></li>
          <li><a href="<%= prefix %>/<%= modPath %>/onintegra">OnIntegra</a></li>
          <li><a href="<%= prefix %>/<%= modPath %>/oncnc">OnCNC</a></li>
          <li><a href="<%= prefix %>/<%= modPath %>/ontmc">OnTMC</a></li>
          <li><a href="<%= prefix %>/<%= modPath %>/onsmartforms">OnSmartForms</a></li>
          <li><a href="<%= prefix %>/<%= modPath %>/onmonitora">OnMonitora</a></li>
        </ul>
      </div>
      <div class="footer__col">
        <h6 class="footer__heading" data-accordion><%= t.footer.company %></h6>
        <ul class="footer__links">
          <li><a href="<%= prefix %>/<%= lang === 'en' ? 'about' : 'hakkimizda' %>"><%= t.nav.about %></a></li>
          <li><a href="<%= prefix %>/<%= lang === 'en' ? 'about' : 'hakkimizda' %>"><%= t.footer.contact %></a></li>
          <li><a href="<%= prefix %>/demo"><%= t.footer.demoRequest %></a></li>
        </ul>
        <h6 class="footer__heading footer__heading--sub" data-accordion><%= t.footer.resources %></h6>
        <ul class="footer__links">
          <li><a href="<%= prefix %>/<%= lang === 'en' ? 'references' : 'referanslar' %>"><%= t.footer.references %></a></li>
          <li><a href="<%= prefix %>/<%= lang === 'en' ? 'references' : 'referanslar' %>"><%= t.footer.partners %></a></li>
        </ul>
      </div>
    </div>
    <div class="footer__bottom">
      <div class="footer__bottom-left">
        <p class="footer__copy">&copy; <%= data.site.copyright %></p>
        <div class="footer__legal">
          <a href="#"><%= t.footer.privacy %></a>
          <span aria-hidden="true">&middot;</span>
          <a href="#"><%= t.footer.cookies %></a>
        </div>
      </div>
      <div class="footer__bottom-right">
        <div class="lang-switch">
          <a href="/" class="lang-switch__btn<%= lang === 'tr' ? ' lang-switch__btn--active' : '' %>" style="color:<%= lang === 'tr' ? '#fff' : 'rgba(255,255,255,.4)' %>;text-decoration:none">TR</a>
          <span class="lang-switch__sep" style="color:rgba(255,255,255,.3)">|</span>
          <a href="/en" class="lang-switch__btn<%= lang === 'en' ? ' lang-switch__btn--active' : '' %>" style="color:<%= lang === 'en' ? '#fff' : 'rgba(255,255,255,.4)' %>;text-decoration:none">EN</a>
        </div>
        <div class="footer__social">
          <a href="#" aria-label="LinkedIn" class="footer__social-link"><svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg></a>
          <a href="#" aria-label="YouTube" class="footer__social-link"><svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg></a>
        </div>
      </div>
    </div>
  </div>
</footer>
