<!-- ============================================================
     HEADER / NAVIGATION
     ============================================================ -->
<a href="#main-content" class="skip-link"><%= lang === 'en' ? 'Skip to main content' : 'Ana icerige atla' %></a>
<header class="header" id="header">
  <div class="container header__inner">
    <a href="<%= prefix %>/" class="header__logo" aria-label="<%= lang === 'en' ? 'OnSuite Home' : 'OnSuite Ana Sayfa' %>">
      <img src="/assets/images/logo.png" alt="OnSuite" width="160" height="40">
    </a>

    <nav class="header__nav" aria-label="<%= lang === 'en' ? 'Main menu' : 'Ana menu' %>">
      <ul class="nav__list">
        <li class="nav__item nav__item--dropdown">
          <button class="nav__link" aria-expanded="false" aria-haspopup="true">
            <%= t.nav.platform %>
            <svg class="nav__chevron" width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <div class="mega-menu">
            <div class="mega-menu__inner">
              <div class="mega-menu__col">
                <span class="mega-menu__label"><%= t.nav.overview %></span>
                <a href="<%= prefix %>/<%= lang === 'en' ? 'modules/onmonitora' : 'moduller/onmonitora' %>" class="mega-menu__item">
                  <div class="mega-menu__icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg></div>
                  <div><span class="mega-menu__name"><%= t.nav.dashboard %></span><span class="mega-menu__desc"><%= t.nav.dashboardDesc %></span></div>
                </a>
                <a href="<%= prefix %>/<%= lang === 'en' ? 'modules/onintegra' : 'moduller/onintegra' %>" class="mega-menu__item">
                  <div class="mega-menu__icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg></div>
                  <div><span class="mega-menu__name"><%= t.nav.integration %></span><span class="mega-menu__desc"><%= t.nav.integrationDesc %></span></div>
                </a>
              </div>
              <div class="mega-menu__col">
                <span class="mega-menu__label"><%= t.nav.capabilities %></span>
                <a href="<%= prefix %>/<%= lang === 'en' ? 'modules/onoptima' : 'moduller/onoptima' %>" class="mega-menu__item">
                  <div class="mega-menu__icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg></div>
                  <div><span class="mega-menu__name"><%= t.nav.oeePerf %></span><span class="mega-menu__desc"><%= t.nav.oeePerfDesc %></span></div>
                </a>
                <a href="<%= prefix %>/<%= lang === 'en' ? 'modules/ontrace' : 'moduller/ontrace' %>" class="mega-menu__item">
                  <div class="mega-menu__icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg></div>
                  <div><span class="mega-menu__name"><%= t.nav.prodTrack %></span><span class="mega-menu__desc"><%= t.nav.prodTrackDesc %></span></div>
                </a>
              </div>
            </div>
          </div>
        </li>

        <li class="nav__item nav__item--dropdown">
          <button class="nav__link" aria-expanded="false" aria-haspopup="true">
            <%= t.nav.modules %>
            <svg class="nav__chevron" width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <% var modPath = lang === 'en' ? 'modules' : 'moduller'; %>
          <div class="mega-menu mega-menu--wide">
            <div class="mega-menu__inner">
              <div class="mega-menu__col">
                <span class="mega-menu__label"><%= t.nav.prodMgmt %></span>
                <a href="<%= prefix %>/<%= modPath %>/ontrace" class="mega-menu__item">
                  <div class="mega-menu__icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><path d="M14 2v6h6"/><path d="M16 13H8"/><path d="M16 17H8"/></svg></div>
                  <div><span class="mega-menu__name">OnTrace</span><span class="mega-menu__desc"><%= lang === 'en' ? 'Traceability' : 'Izlenebilirlik' %></span></div>
                </a>
                <a href="<%= prefix %>/<%= modPath %>/onoptima" class="mega-menu__item">
                  <div class="mega-menu__icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg></div>
                  <div><span class="mega-menu__name">OnOptima</span><span class="mega-menu__desc"><%= lang === 'en' ? 'Production Optimization' : 'Uretim Optimizasyonu' %></span></div>
                </a>
                <a href="<%= prefix %>/<%= modPath %>/onconnect" class="mega-menu__item">
                  <div class="mega-menu__icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 12h8"/><path d="M12 8v8"/><circle cx="5" cy="12" r="2"/><circle cx="19" cy="12" r="2"/></svg></div>
                  <div><span class="mega-menu__name">OnConnect</span><span class="mega-menu__desc"><%= lang === 'en' ? 'Machine Connectivity' : 'Makine Baglantisi' %></span></div>
                </a>
              </div>
              <div class="mega-menu__col">
                <span class="mega-menu__label"><%= t.nav.dataInteg %></span>
                <a href="<%= prefix %>/<%= modPath %>/onintegra" class="mega-menu__item">
                  <div class="mega-menu__icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg></div>
                  <div><span class="mega-menu__name">OnIntegra</span><span class="mega-menu__desc"><%= lang === 'en' ? 'ERP Integration' : 'ERP Entegrasyonu' %></span></div>
                </a>
                <a href="<%= prefix %>/<%= modPath %>/onmonitora" class="mega-menu__item">
                  <div class="mega-menu__icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8"/><path d="M12 17v4"/></svg></div>
                  <div><span class="mega-menu__name">OnMonitora</span><span class="mega-menu__desc"><%= lang === 'en' ? 'Machine Monitoring' : 'Makine Izleme' %></span></div>
                </a>
                <a href="<%= prefix %>/<%= modPath %>/oncnc" class="mega-menu__item">
                  <div class="mega-menu__icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg></div>
                  <div><span class="mega-menu__name">OnCNC</span><span class="mega-menu__desc"><%= lang === 'en' ? 'CNC Data Collection' : 'CNC Veri Toplama' %></span></div>
                </a>
              </div>
              <div class="mega-menu__col">
                <span class="mega-menu__label"><%= t.nav.sectoral %></span>
                <a href="<%= prefix %>/<%= modPath %>/ontmc" class="mega-menu__item">
                  <div class="mega-menu__icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 22s-8-4.5-8-11.8A8 8 0 0112 2a8 8 0 018 8.2c0 7.3-8 11.8-8 11.8z"/></svg></div>
                  <div><span class="mega-menu__name">OnTMC</span><span class="mega-menu__desc"><%= lang === 'en' ? 'Tobacco Industry' : 'Tutun Sektoru' %></span></div>
                </a>
                <a href="<%= prefix %>/<%= modPath %>/onsmartforms" class="mega-menu__item">
                  <div class="mega-menu__icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg></div>
                  <div><span class="mega-menu__name">OnSmartForms</span><span class="mega-menu__desc"><%= lang === 'en' ? 'Digital Forms' : 'Dijital Formlar' %></span></div>
                </a>
                <a href="<%= prefix %>/<%= modPath %>/oncarboniq" class="mega-menu__item">
                  <div class="mega-menu__icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 22L12 2l10 20H2z"/><path d="M12 9v5"/><circle cx="12" cy="17" r="1"/></svg></div>
                  <div><span class="mega-menu__name">OnCarboniq</span><span class="mega-menu__desc"><%= lang === 'en' ? 'Carbon Footprint' : 'Karbon Ayak Izi' %></span></div>
                </a>
                <a href="<%= prefix %>/<%= modPath %>/oncore" class="mega-menu__item">
                  <div class="mega-menu__icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="3"/><circle cx="12" cy="12" r="8"/><circle cx="12" cy="12" r="1"/></svg></div>
                  <div><span class="mega-menu__name">OnCore</span><span class="mega-menu__desc"><%= lang === 'en' ? 'Core Platform' : 'Temel Platform' %></span></div>
                </a>
              </div>
            </div>
            <div class="mega-menu__footer">
              <a href="<%= prefix %>/#modules" class="btn--link"><%= t.nav.exploreAll %> <span class="btn__arrow" aria-hidden="true">&rarr;</span></a>
            </div>
          </div>
        </li>

        <li class="nav__item"><a href="<%= prefix %>/<%= lang === 'en' ? 'industries' : 'sektorler' %>" class="nav__link"><%= t.nav.sectors %></a></li>
        <li class="nav__item"><a href="<%= prefix %>/<%= lang === 'en' ? 'references' : 'referanslar' %>" class="nav__link"><%= t.nav.resources %></a></li>
        <li class="nav__item"><a href="<%= prefix %>/<%= lang === 'en' ? 'about' : 'hakkimizda' %>" class="nav__link"><%= t.nav.about %></a></li>
      </ul>
    </nav>

    <div class="header__actions">
      <div class="lang-switch" aria-label="<%= lang === 'en' ? 'Language selection' : 'Dil secimi' %>">
        <% var currentPath = typeof currentUrl !== 'undefined' ? currentUrl : ''; %>
        <a href="/" class="lang-switch__btn<%= lang === 'tr' ? ' lang-switch__btn--active' : '' %>" style="text-decoration:none"<%= lang === 'tr' ? ' aria-current="true"' : '' %>>TR</a>
        <span class="lang-switch__sep" aria-hidden="true">|</span>
        <a href="/en" class="lang-switch__btn<%= lang === 'en' ? ' lang-switch__btn--active' : '' %>" style="text-decoration:none"<%= lang === 'en' ? ' aria-current="true"' : '' %>>EN</a>
      </div>
      <a href="<%= prefix %>/<%= lang === 'en' ? 'demo' : 'demo' %>" class="btn btn--primary btn--sm header__cta">
        <%= t.nav.demo %>
        <svg class="btn__arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M3.33 8h9.34M8.67 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>

    <button class="header__hamburger" aria-label="Menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<!-- Mobile Menu -->
<div class="mobile-menu" id="mobileMenu" aria-hidden="true">
  <div class="mobile-menu__inner">
    <div class="mobile-menu__top">
      <a href="<%= prefix %>/" class="header__logo"><img src="/assets/images/logo.png" alt="OnSuite" width="140" height="35"></a>
      <button class="mobile-menu__close" id="mobileMenuClose" aria-label="<%= lang === 'en' ? 'Close' : 'Kapat' %>">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
    </div>
    <nav aria-label="<%= lang === 'en' ? 'Mobile menu' : 'Mobil menu' %>">
      <ul class="mobile-menu__list">
        <li class="mobile-menu__item mobile-menu__item--accordion">
          <button class="mobile-menu__toggle" aria-expanded="false">
            <%= t.nav.modules %>
            <svg class="mobile-menu__plus" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M10 4v12M4 10h12"/></svg>
          </button>
          <div class="mobile-menu__sub" hidden>
            <a href="<%= prefix %>/<%= modPath %>/ontrace" class="mobile-menu__sublink">OnTrace</a>
            <a href="<%= prefix %>/<%= modPath %>/onoptima" class="mobile-menu__sublink">OnOptima</a>
            <a href="<%= prefix %>/<%= modPath %>/onconnect" class="mobile-menu__sublink">OnConnect</a>
            <a href="<%= prefix %>/<%= modPath %>/onintegra" class="mobile-menu__sublink">OnIntegra</a>
            <a href="<%= prefix %>/<%= modPath %>/onmonitora" class="mobile-menu__sublink">OnMonitora</a>
            <a href="<%= prefix %>/<%= modPath %>/oncnc" class="mobile-menu__sublink">OnCNC</a>
            <a href="<%= prefix %>/<%= modPath %>/ontmc" class="mobile-menu__sublink">OnTMC</a>
            <a href="<%= prefix %>/<%= modPath %>/onsmartforms" class="mobile-menu__sublink">OnSmartForms</a>
            <a href="<%= prefix %>/<%= modPath %>/oncarboniq" class="mobile-menu__sublink">OnCarboniq</a>
            <a href="<%= prefix %>/<%= modPath %>/oncore" class="mobile-menu__sublink">OnCore</a>
          </div>
        </li>
        <li class="mobile-menu__item"><a href="<%= prefix %>/<%= lang === 'en' ? 'industries' : 'sektorler' %>" class="mobile-menu__link"><%= t.nav.sectors %></a></li>
        <li class="mobile-menu__item"><a href="<%= prefix %>/<%= lang === 'en' ? 'references' : 'referanslar' %>" class="mobile-menu__link"><%= t.nav.resources %></a></li>
        <li class="mobile-menu__item"><a href="<%= prefix %>/<%= lang === 'en' ? 'about' : 'hakkimizda' %>" class="mobile-menu__link"><%= t.nav.about %></a></li>
      </ul>
    </nav>
    <div class="mobile-menu__footer">
      <a href="<%= prefix %>/demo" class="btn btn--primary" style="width:100%"><%= t.nav.demo %> <span class="btn__arrow">&rarr;</span></a>
      <div class="lang-switch" style="justify-content:center;margin-top:var(--s4)">
        <a href="/" class="lang-switch__btn<%= lang === 'tr' ? ' lang-switch__btn--active' : '' %>" style="text-decoration:none">TR</a>
        <span class="lang-switch__sep">|</span>
        <a href="/en" class="lang-switch__btn<%= lang === 'en' ? ' lang-switch__btn--active' : '' %>" style="text-decoration:none">EN</a>
      </div>
    </div>
  </div>
</div>
