<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= t.demo.pageTitle %> - OnSuite | <%= data.site.title %></title>
  <meta name="description" content="<%= t.demo.desc %>">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/design-system.css">
  <link rel="stylesheet" href="/css/pages.css">
  <link rel="stylesheet" href="/css/demo.css">
  <link rel="icon" type="image/png" href="/assets/images/favicon.png">
</head>
<body>

<header class="demo-header">
  <div class="container">
    <div class="demo-header__inner">
      <a href="<%= prefix %>/" class="demo-header__logo">
        <img src="/assets/images/logo.png" alt="OnSuite" width="120" height="28">
      </a>
      <div style="display:flex;align-items:center;gap:16px">
        <div class="lang-switch" style="display:flex;align-items:center;gap:6px">
          <a href="/demo" style="text-decoration:none;font-size:13px;font-weight:600;color:<%= lang === 'tr' ? '#0089CF' : '#9ca3af' %>">TR</a>
          <span style="color:#e5e7eb">|</span>
          <a href="/en/demo" style="text-decoration:none;font-size:13px;font-weight:600;color:<%= lang === 'en' ? '#0089CF' : '#9ca3af' %>">EN</a>
        </div>
        <a href="<%= prefix %>/" class="demo-header__back">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M12.5 15L7.5 10l5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          <%= t.nav.backToHome %>
        </a>
      </div>
    </div>
  </div>
</header>

<main class="demo-page">
  <div class="container">
    <div class="demo-grid">
      <div class="demo-info">
        <h1 class="demo-info__title"><%= t.demo.title %></h1>
        <p class="demo-info__desc"><%= t.demo.desc %></p>
        <div class="demo-info__checklist">
          <div class="demo-info__check">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M5 10l3.5 3.5L15 6" stroke="#04bf8a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span><%= t.demo.check1 %></span>
          </div>
          <div class="demo-info__check">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M5 10l3.5 3.5L15 6" stroke="#04bf8a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span><%= t.demo.check2 %></span>
          </div>
          <div class="demo-info__check">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M5 10l3.5 3.5L15 6" stroke="#04bf8a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span><%= t.demo.check3 %></span>
          </div>
          <div class="demo-info__check">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M5 10l3.5 3.5L15 6" stroke="#04bf8a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            <span><%= t.demo.check4 %></span>
          </div>
        </div>
        <div class="demo-info__social">
          <p class="demo-info__social-text"><%= t.demo.socialProof %></p>
          <div class="demo-info__logos">
            <span class="demo-info__logo-tag">Bosch</span>
            <span class="demo-info__logo-tag">BSH</span>
            <span class="demo-info__logo-tag">Unilever</span>
            <span class="demo-info__logo-tag">Haier</span>
            <span class="demo-info__logo-tag">Diageo</span>
          </div>
        </div>
      </div>

      <div class="demo-form-wrap">
        <div class="demo-form-card" id="demoFormCard">
          <h2 class="demo-form__heading"><%= t.demo.formTitle %></h2>
          <form id="demoForm" class="demo-form" novalidate>
            <div class="demo-field">
              <label for="df-name"><%= t.demo.name %> <span class="req">*</span></label>
              <input type="text" id="df-name" name="name" required placeholder="<%= t.demo.namePlaceholder %>">
            </div>
            <div class="demo-field">
              <label for="df-email"><%= t.demo.email %> <span class="req">*</span></label>
              <input type="email" id="df-email" name="email" required placeholder="<%= t.demo.emailPlaceholder %>">
            </div>
            <div class="demo-field">
              <label for="df-phone"><%= t.demo.phoneLbl %> <span class="req">*</span></label>
              <input type="tel" id="df-phone" name="phone" required placeholder="<%= t.demo.phonePlaceholder %>">
            </div>
            <div class="demo-field">
              <label for="df-company"><%= t.demo.company %> <span class="req">*</span></label>
              <input type="text" id="df-company" name="company" required placeholder="<%= t.demo.companyPlaceholder %>">
            </div>
            <div class="demo-field-row">
              <div class="demo-field">
                <label for="df-sector"><%= t.demo.sector %> <span class="req">*</span></label>
                <select id="df-sector" name="sector" required>
                  <option value=""><%= t.demo.selectSector %></option>
                  <% Object.keys(t.demo.sectorOptions).forEach(function(key) { %>
                    <option value="<%= key %>"><%= t.demo.sectorOptions[key] %></option>
                  <% }); %>
                </select>
              </div>
              <div class="demo-field">
                <label for="df-lines"><%= t.demo.lines %></label>
                <select id="df-lines" name="productionLines">
                  <option value=""><%= t.demo.selectLines %></option>
                  <% Object.keys(t.demo.lineOptions).forEach(function(key) { %>
                    <option value="<%= key %>"><%= t.demo.lineOptions[key] %></option>
                  <% }); %>
                </select>
              </div>
            </div>
            <div class="demo-field">
              <label for="df-message"><%= t.demo.message %> <span class="opt">(<%= t.demo.optional %>)</span></label>
              <textarea id="df-message" name="message" rows="3" placeholder="<%= t.demo.messagePlaceholder %>"></textarea>
            </div>
            <button type="submit" class="demo-form__submit" id="demoSubmitBtn">
              <%= t.demo.submit %> <span aria-hidden="true">&rarr;</span>
            </button>
            <p class="demo-form__privacy">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 1.75a2.625 2.625 0 00-2.625 2.625V5.25h5.25V4.375A2.625 2.625 0 007 1.75z" stroke="#9ca3af" stroke-width="1.2"/><rect x="2.625" y="5.25" width="8.75" height="6.125" rx="1.5" stroke="#9ca3af" stroke-width="1.2"/></svg>
              <%= t.demo.privacy %>
            </p>
          </form>
        </div>

        <div class="demo-success" id="demoSuccess" style="display:none">
          <div class="demo-success__icon">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><circle cx="24" cy="24" r="22" stroke="#04bf8a" stroke-width="2.5"/><path d="M15 24l6.5 6.5L33 17" stroke="#04bf8a" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <h2 class="demo-success__title"><%= t.demo.successTitle %></h2>
          <p class="demo-success__desc"><%= t.demo.successDesc %></p>
          <a href="<%= prefix %>/" class="demo-success__link"><%= t.demo.successLink %> <span aria-hidden="true">&rarr;</span></a>
        </div>
      </div>
    </div>
  </div>
</main>

<script>
(function() {
  var form = document.getElementById('demoForm');
  var card = document.getElementById('demoFormCard');
  var success = document.getElementById('demoSuccess');
  var submitBtn = document.getElementById('demoSubmitBtn');
  var submitText = '<%= t.demo.submit %>';
  var sendingText = '<%= t.demo.sending %>';
  var errorReq = '<%= t.demo.errorRequired %>';
  var errorGen = '<%= t.demo.errorGeneral %>';
  var errorConn = '<%= t.demo.errorConnection %>';

  var params = new URLSearchParams(window.location.search);
  if (params.get('sector')) { var sel = document.getElementById('df-sector'); if (sel) sel.value = params.get('sector'); }
  if (params.get('lines')) { var sel2 = document.getElementById('df-lines'); if (sel2) sel2.value = params.get('lines'); }

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    var fields = form.querySelectorAll('[required]');
    var valid = true;
    fields.forEach(function(f) { f.classList.remove('demo-field--error'); if (!f.value.trim()) { f.classList.add('demo-field--error'); valid = false; } });
    var email = document.getElementById('df-email');
    if (email.value && !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value)) { email.classList.add('demo-field--error'); valid = false; }
    if (!valid) return;

    submitBtn.disabled = true;
    submitBtn.textContent = sendingText;

    fetch('/api/demo', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        name: form.name.value.trim(), email: form.email.value.trim(), phone: form.phone.value.trim(),
        company: form.company.value.trim(), sector: form.sector.value,
        productionLines: form.productionLines.value, message: form.message.value.trim(),
        lang: '<%= lang %>'
      })
    })
    .then(function(res) { return res.json(); })
    .then(function(data) {
      if (data.ok) { card.style.display = 'none'; success.style.display = 'block'; }
      else { submitBtn.disabled = false; submitBtn.innerHTML = submitText + ' <span>&rarr;</span>'; alert(data.error || errorGen); }
    })
    .catch(function() { submitBtn.disabled = false; submitBtn.innerHTML = submitText + ' <span>&rarr;</span>'; alert(errorConn); });
  });
})();
</script>
<%- include('partials/chatbot') %>
<script src="/js/main.js"></script>
</body>
</html>
